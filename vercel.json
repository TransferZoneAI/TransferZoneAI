{
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" }
  ],
  "crons": [
    {
      "path": "/api/transfers-daily",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/notify-transfers",
      "schedule": "30 3 * * *"
    },
    {
      "path": "/api/notify-prematch",
      "schedule": "0 * * * *"
    }
  ]
}
