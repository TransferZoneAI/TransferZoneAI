    { "source": "/player/:slug", "destination": "/" },
    { "source": "/club/:slug", "destination": "/" },
    { "source": "/league/:slug", "destination": "/" },
    { "source": "/match/:id", "destination": "/" },
    { "source": "/transfers", "destination": "/" },
    { "source": "/live", "destination": "/" },
    { "source": "/toplists", "destination": "/" },
    { "source": "/myclubs", "destination": "/" }
